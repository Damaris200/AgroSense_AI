generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Farm {
  id           String   @id @default(uuid())
  submissionId String   @unique
  userId       String
  cropType     String
  location     String
  gpsLat       Float
  gpsLng       Float
  createdAt    DateTime @default(now())

  @@map("farms")
}