{
  "name": "agrosense-notification-service",
  "version": "1.0.0",
  "description": "AgroSense AI — Notification microservice (email via Nodemailer)",
  "module": "src/index.ts",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "start:docker": "bunx prisma migrate deploy && bun src/index.ts",
    "test": "bun test --coverage",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "dotenv": "^16.4.5",
    "kafkajs": "^2.2.4",
    "nodemailer": "^6.9.14",
    "pg": "^8.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.14.9",
    "@types/nodemailer": "^6.4.15",
    "@types/pg": "^8.11.0",
    "prisma": "^7.0.0",
    "typescript": "^5.5.3"
  }
}
