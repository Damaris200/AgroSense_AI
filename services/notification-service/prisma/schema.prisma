generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
 
}

model Notification {
  id      String   @id @default(auto()) @map("_id") @db.ObjectId
  userId  String   @map("user_id")
  farmId  String   @map("farm_id")
  message String
  channel String
  sentAt  DateTime @default(now()) @map("sent_at")

  @@map("notifications")
  @@index([userId])
  @@index([farmId])
}
