generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  // Connection URLs are no longer supported in schema files.
  // Move connection URLs to prisma.config.ts and pass adapter or accelerateUrl
  // to the PrismaClient constructor. See https://pris.ly/d/config-datasource
}

model Recommendation {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  farmId       String   @map("farm_id")
  userId       String   @default("anonymous") @map("user_id")
  submissionId String   @map("submission_id")
  content      String
  model        String
  generatedAt  DateTime @default(now()) @map("generated_at")

  @@index([farmId])
  @@index([submissionId])
  @@map("recommendations")
}
