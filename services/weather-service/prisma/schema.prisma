generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
 
}

model WeatherData {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  farmId      String   @map("farm_id")
  temperature Float
  humidity    Float
  rainfall    Float
  windSpeed   Float    @map("wind_speed")
  description String
  fetchedAt   DateTime @default(now()) @map("fetched_at")

  @@index([farmId])
  @@map("weather_data")
}
