generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model WeatherData {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  farmId       String   @map("farm_id") @db.Uuid   // cross-DB ref to farm_db.farms — no FK enforced
  temperature  Float
  humidity     Float
  rainfall     Float
  forecastJson Json     @map("forecast_json")
  fetchedAt    DateTime @default(now()) @map("fetched_at")

  @@map("weather_data")
}
