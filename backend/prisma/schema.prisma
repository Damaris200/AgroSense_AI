generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum Role {
  farmer
  agronomist
  admin
}

enum Locale {
  en
  fr
}

enum Urgency {
  low
  medium
  high
}

enum RecommendationSource {
  rule
  ai
  hybrid
}

enum ReviewStatus {
  pending
  accepted
  overridden
}

// ── Models ────────────────────────────────────────────────────────────────────

// Users 
model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  email        String   @unique
  phone        String?
  passwordHash String   @map("password_hash")
  role         Role     @default(farmer)
  locale       Locale   @default(en)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  farms         Farm[]
  notifications Notification[]
  reviewedRecs  Recommendation[] @relation("ReviewedBy")

  @@map("users")
}

// Farms 
model Farm {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String  @map("user_id") @db.Uuid
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  latitude  Float
  longitude Float
  sizeHa    Decimal @map("size_ha") @db.Decimal(8, 2)
  soilType  String? @map("soil_type")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  crops            Crop[]
  observations     Observation[]
  weatherSnapshots WeatherSnapshot[]
  recommendations  Recommendation[]

  @@index([userId])
  @@map("farms")
}

// Crops 
model Crop {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  farmId          String    @map("farm_id") @db.Uuid
  farm            Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  cropType        String    @map("crop_type")
  plantingDate    DateTime  @map("planting_date") @db.Date
  expectedHarvest DateTime? @map("expected_harvest") @db.Date
  createdAt       DateTime  @default(now()) @map("created_at")

  observations Observation[]

  @@index([farmId])
  @@map("crops")
}

// Observations 
model Observation {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  farmId       String   @map("farm_id") @db.Uuid
  farm         Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  cropId       String?  @map("crop_id") @db.Uuid
  crop         Crop?    @relation(fields: [cropId], references: [id], onDelete: SetNull)
  soilMoisture Decimal? @map("soil_moisture") @db.Decimal(5, 2)
  temperatureC Decimal? @map("temperature_c") @db.Decimal(5, 2)
  notes        String?
  observedAt   DateTime @default(now()) @map("observed_at")
  createdAt    DateTime @default(now()) @map("created_at")

  recommendations Recommendation[]

  @@index([farmId, observedAt(sort: Desc)])
  @@map("observations")
}

// Weather snapshots 
model WeatherSnapshot {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  farmId       String   @map("farm_id") @db.Uuid
  farm         Farm     @relation(fields: [farmId], references: [id], onDelete: Cascade)
  temperatureC Decimal? @map("temperature_c") @db.Decimal(5, 2)
  humidityPct  Decimal? @map("humidity_pct") @db.Decimal(5, 2)
  rainfallMm   Decimal? @map("rainfall_mm") @db.Decimal(6, 2)
  windKph      Decimal? @map("wind_kph") @db.Decimal(5, 2)
  condition    String?
  forecastJson Json?    @map("forecast_json")
  fetchedAt    DateTime @default(now()) @map("fetched_at")

  @@index([farmId, fetchedAt(sort: Desc)])
  @@map("weather_snapshots")
}

// Recommendations 
model Recommendation {
  id            String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  farmId        String               @map("farm_id") @db.Uuid
  farm          Farm                 @relation(fields: [farmId], references: [id], onDelete: Cascade)
  observationId String?              @map("observation_id") @db.Uuid
  observation   Observation?         @relation(fields: [observationId], references: [id], onDelete: SetNull)
  eventId       String               @unique @map("event_id")
  action        String
  urgency       Urgency
  message       String
  source        RecommendationSource
  contextJson   Json?                @map("context_json")
  reviewedById  String?              @map("reviewed_by") @db.Uuid
  reviewedBy    User?                @relation("ReviewedBy", fields: [reviewedById], references: [id])
  reviewStatus  ReviewStatus         @default(pending) @map("review_status")
  createdAt     DateTime             @default(now()) @map("created_at")

  notifications Notification[]

  @@index([farmId, createdAt(sort: Desc)])
  @@map("recommendations")
}

// Notifications 1`
model Notification {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String          @map("user_id") @db.Uuid
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendationId String?         @map("recommendation_id") @db.Uuid
  recommendation   Recommendation? @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  title            String
  body             String
  isRead           Boolean         @default(false) @map("is_read")
  createdAt        DateTime        @default(now()) @map("created_at")

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
}
